<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Experiences"
            android:textSize="26sp"
            android:textColor="#1565C0"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="20dp" />

        <!-- ==================== EDUCATION ==================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="EDUCATION"
            android:textSize="16sp"
            android:textColor="#1565C0"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="4dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#1565C0"
            android:layout_marginBottom="12dp" />

        <!-- Education Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="24dp"
            android:elevation="2dp">

            <TextView
                android:id="@+id/tvEduSchool"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#212121" />

            <TextView
                android:id="@+id/tvEduPeriod"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="#888888"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvEduMajor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#424242"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvEduDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="#616161"
                android:lineSpacingExtra="3dp" />
        </LinearLayout>

        <!-- ==================== PROFESSIONAL EXPERIENCE ==================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PROFESSIONAL EXPERIENCE"
            android:textSize="16sp"
            android:textColor="#1565C0"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="4dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#1565C0"
            android:layout_marginBottom="12dp" />

        <!-- Work Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp">

            <TextView
                android:id="@+id/tvWorkTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#212121" />

            <TextView
                android:id="@+id/tvWorkPlace"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textColor="#424242"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvWorkPeriod"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="#888888"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvWorkDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="#616161"
                android:lineSpacingExtra="3dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
