<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Projects"
            android:textSize="26sp"
            android:textColor="#1565C0"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#1565C0"
            android:layout_marginBottom="16dp" />

        <!-- ==================== Project 1 ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="20dp"
                    android:background="#1565C0"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvProj1Title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text=""
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#212121" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvProj1Period"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvProj1Tech"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="#1976D2"
                android:textStyle="italic"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvProj1Desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="#616161"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

        <!-- ==================== Project 2 ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="20dp"
                    android:background="#2E7D32"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvProj2Title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text=""
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#212121" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvProj2Period"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvProj2Tech"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="#2E7D32"
                android:textStyle="italic"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvProj2Desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="#616161"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

        <!-- ==================== Project 3 ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="20dp"
                    android:background="#E65100"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvProj3Title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text=""
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#212121" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvProj3Period"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvProj3Tech"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="#E65100"
                android:textStyle="italic"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvProj3Desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="#616161"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
